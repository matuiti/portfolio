{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "compile:scss:ui": "sass public/gallery-ui:public/gallery-ui --no-source-map --style=compressed",
    "compile:scss:animation": "sass public/gallery-animation:public/gallery-animation --no-source-map --style=compressed",
    "compile:scss": "npm run compile:scss:ui && npm run compile:scss:animation",
    "watch:scss:ui": "sass public/gallery-ui:public/gallery-ui --watch --style=expanded",
    "watch:scss:animation": "sass public/gallery-animation:public/gallery-animation --watch --style=expanded",
    "watch:scss": "npm run watch:scss:ui & npm run watch:scss:animation",
    "prebuild": "npm run compile:scss"
  },
  "dependencies": {
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sass": "^1.97.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
