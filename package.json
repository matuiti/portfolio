{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "// --- Development Environment ---": "",
    "dev:work": "npm-run-all --parallel watch:scss dev",
    "new": "node scripts/generate-ui-part.mjs",
    "new:icon": "node scripts/generate-svg-icon.mjs",
    "// --- Sass & Watchers ---": "",
    "watch:scss": "sass public/gallery-parts:public/gallery-parts --watch --style=expanded --load-path=public/gallery-parts/common/css",
    "compile:scss": "sass public/gallery-parts:public/gallery-parts --no-source-map --style=compressed --load-path=public/gallery-parts/common/css",
    "// --- Lifecycle Hooks ---": "",
    "prebuild": "npm run compile:scss",
    "postinstall": "npm run compile:scss"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-email/components": "1.0.7",
    "@react-email/render": "^2.0.4",
    "gsap": "^3.14.2",
    "lucide-react": "^0.563.0",
    "next": "16.1.1",
    "prismjs": "^1.30.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-email": "5.2.8",
    "react-hook-form": "^7.71.1",
    "react-turnstile": "^1.1.5",
    "resend": "^6.9.2",
    "sass": "^1.97.2",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "chokidar": "^5.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "npm-run-all": "^4.1.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
