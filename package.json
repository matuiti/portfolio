{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",

    "// --- Development Environment ---": "",
    "dev:work": "npm-run-all --parallel watch:scss dev",
    "new": "node scripts/generate-ui-part.js",

    "// --- Sass & Watchers ---": "",
    "watch:scss": "sass public/gallery-parts:public/gallery-parts --watch --style=expanded --load-path=public/gallery-parts/common/css",
    "compile:scss": "sass public/gallery-parts:public/gallery-parts --no-source-map --style=compressed --load-path=public/gallery-parts/common/css",

    "// --- Lifecycle Hooks ---": "",
    "prebuild": "npm run compile:scss",
    "postinstall": "npm run compile:scss"
  },
  "dependencies": {
    "next": "16.1.1",
    "prismjs": "^1.30.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sass": "^1.97.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "chokidar": "^5.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "npm-run-all": "^4.1.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}