{
  "output": {
    "filePath": "repomix-output.md",
    "style": "markdown",
    "removeComments": false,
    "showLineNumbers": false
  },
  "ignore": {
    "customPatterns": [
      "node_modules",
      ".git",
      ".next/**/*",
      "dist/**/*",
      "package-lock.json",
      "yarn.lock",
      "**/*.css",
      "**/*.css.map",
      "**/*.map",
      "**/*.png",
      "**/*.jpg",
      "**/*.jpeg",
      "**/*.gif",
      "**/*.svg",
      "**/*.ico",
      "repomix-*"
    ],
    "useGitignore": true,
    "useDefaultIgnore": true
  },
  "security": {
    "enableSecurityCheck": true
  }
}
