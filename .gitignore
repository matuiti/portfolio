# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Sass
.sass-cache/
*.css.map

# コンパイル済みCSS（SCSSから自動生成されるもの）
public/ui-collection-static/**/*.css
public/animation-gallery/**/*.css

# エディタ
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store

# パフォーマンス計測結果
.lighthouse/

# テキストを一旦整形する仮置き場
memo.txt
